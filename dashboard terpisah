<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analytics Pro - Business Intelligence</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet">
    <script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-database-compat.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        :root { --purple-main: #7c3aed; --bg-dark: #0f0a19; --card-dark: #1a1425; --text-muted: #94a3b8; }
        body { margin: 0; font-family: 'Plus Jakarta Sans', sans-serif; background: var(--bg-dark); color: white; padding-bottom: 90px; }
        
        .header { padding: 25px 20px; display: flex; justify-content: space-between; align-items: center; }
        .brand { display: flex; align-items: center; gap: 10px; }
        .logo-box { background: #7c3aed; padding: 8px; border-radius: 10px; }

        .container { padding: 0 20px; max-width: 600px; margin: auto; }
        
        /* ACTION BUTTONS (Screen 9) */
        .action-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 25px; }
        .btn-opt { background: var(--card-dark); border: 1.5px solid #2d243d; padding: 18px; border-radius: 20px; color: white; display: flex; align-items: center; justify-content: center; gap: 10px; font-weight: 700; cursor: pointer; font-size: 14px; }
        .btn-opt.primary { background: #6d28d9; border: none; }

        /* OVERVIEW CARDS */
        .main-card { background: linear-gradient(135deg, #6d28d9, #4c1d95); border-radius: 24px; padding: 25px; margin-bottom: 15px; position: relative; overflow: hidden; }
        .main-card::after { content: '💵'; position: absolute; right: 20px; top: 20px; opacity: 0.2; font-size: 40px; }
        
        .stat-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 25px; }
        .mini-card { background: var(--card-dark); padding: 20px; border-radius: 24px; border: 1.5px solid #2d243d; }

        /* CHARTS SECTION */
        .chart-box { background: var(--card-dark); border-radius: 24px; padding: 20px; border: 1.5px solid #2d243d; margin-bottom: 15px; }
        .chart-title { font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px; color: #cbd5e1; }

        /* INVENTORY ALERT (Screen 9 bottom) */
        .alert-box { background: #1a1425; border: 1px solid #2d243d; padding: 20px; border-radius: 20px; display: flex; justify-content: space-between; align-items: center; }

        /* NAVIGASI (Sesuai Screen 9) */
        .nav { position: fixed; bottom: 0; width: 100%; background: #150e21; display: flex; border-top: 1px solid #251b36; padding: 15px 0; z-index: 1000; }
        .nav-item { flex: 1; text-align: center; font-size: 10px; font-weight: 700; color: #4b5563; cursor: pointer; }
        .nav-item.active { color: #a78bfa; }
        .nav-item b { font-size: 20px; display: block; margin-bottom: 4px; }

        .hidden { display: none; }
    </style>
</head>
<body>

<div class="header">
    <div class="brand">
        <div class="logo-box">📊</div>
        <div>
            <div style="font-weight: 800; font-size: 14px;">Analytics Pro</div>
            <div style="font-size: 10px; color: var(--purple-main); font-weight: 700;">BUSINESS INTELLIGENCE</div>
        </div>
    </div>
    <div style="background: #1a1425; padding: 10px; border-radius: 50%;">🔔</div>
</div>

<div class="container" id="view-home">
    <h1 style="font-size: 28px; font-weight: 800; margin: 0 0 5px;">Overview</h1>
    <p style="color: var(--text-muted); font-size: 13px; margin-bottom: 25px;">Real-time performance metrics</p>

    <div class="action-grid">
        <div class="btn-opt primary">🖨️ Cetak Laporan</div>
        <div class="btn-opt">📥 Download Data</div>
    </div>

    <div class="main-card">
        <div style="font-size: 12px; font-weight: 700; color: #e9d5ff;">Total Setoran</div>
        <div style="font-size: 32px; font-weight: 800; margin: 8px 0;" id="val-setoran">Rp 0</div>
        <div style="background: rgba(255,255,255,0.1); display: inline-block; padding: 4px 10px; border-radius: 20px; font-size: 11px;">+0% vs last month</div>
    </div>

    <div class="stat-row">
        <div class="mini-card">
            <div style="color: var(--text-muted); font-size: 11px; font-weight: 700;">Total Laporan 📄</div>
            <div style="font-size: 24px; font-weight: 800; margin: 5px 0;" id="val-laporan">0</div>
            <div style="font-size: 10px; color: #94a3b8;">Laporan baru hari ini</div>
        </div>
        <div class="mini-card">
            <div style="color: var(--text-muted); font-size: 11px; font-weight: 700;">Stok Gudang 📦</div>
            <div style="font-size: 24px; font-weight: 800; margin: 5px 0;" id="val-gudang">0</div>
            <div style="font-size: 10px; color: #94a3b8;">Total item tersedia</div>
        </div>
    </div>

    <div class="chart-box">
        <div class="chart-title">Setoran Volume (Last 7 Days)</div>
        <canvas id="chartSetoran" style="height: 150px;"></canvas>
    </div>

    <div class="chart-box">
        <div class="chart-title">Laporan Activity</div>
        <div style="text-align: center; color: #4b5563; padding: 40px 0; font-size: 12px;">Waiting for data...</div>
    </div>

    <div class="alert-box">
        <div>
            <div style="font-weight: 800; font-size: 14px;">Inventory Alert</div>
            <div style="font-size: 12px; color: #94a3b8;">0 items need restocking soon</div>
        </div>
        <div style="background: #1a1425; padding: 12px; border-radius: 50%; border: 1px solid #2d243d;">🔔</div>
    </div>
</div>

<nav class="nav">
    <div class="nav-item active"><b>🏠</b>Home</div>
    <div class="nav-item"><b>💰</b>Setoran</div>
    <div class="nav-item"><b>📄</b>Laporan</div>
    <div class="nav-item"><b>📦</b>Inventory</div>
    <div class="nav-item" onclick="alert('Buka app_input.html untuk Setting')"><b>⚙️</b>Settings</div>
</nav>

<script>
    // FIREBASE CONFIG (Tetap pakai yang tadi supaya data sinkron)
    const firebaseConfig = {
        apiKey: "AIzaSyDj1f5YlwkT8ZraW9l7QZe6cQTgjsTSPBs",
        databaseURL: "https://tempat-masuk-nya-data-default-rtdb.firebaseio.com"
    };

    if (!firebase.apps.length) firebase.initializeApp(firebaseConfig);
    const db = firebase.database();

    // Fungsi Update Angka Real-time
    function fetchData() {
        // 1. Ambil Total Setoran
        db.ref('db_gibran/setoran').on('value', snap => {
            let total = 0;
            snap.forEach(c => { total += Number(c.val().nominal || 0); });
            document.getElementById('val-setoran').innerText = "Rp " + total.toLocaleString('id-ID');
        });

        // 2. Ambil Count Laporan
        db.ref('db_gibran/laporan').on('value', snap => {
            document.getElementById('val-laporan').innerText = snap.numChildren();
        });

        // 3. Ambil Count Gudang
        db.ref('db_gibran/gudang').on('value', snap => {
            document.getElementById('val-gudang').innerText = snap.numChildren();
        });
    }

    // Chart.js (Grafik Batang Screen 9)
    const ctx = document.getElementById('chartSetoran').getContext('2d');
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Today'],
            datasets: [{
                data: [12, 19, 13, 17, 14, 25, 8],
                backgroundColor: '#7c3aed',
                borderRadius: 8,
                barThickness: 15
            }]
        },
        options: {
            plugins: { legend: { display: false } },
            scales: {
                y: { display: false },
                x: { grid: { display: false }, ticks: { color: '#64748b' } }
            }
        }
    });

    fetchData();
</script>
</body>
</html>
